<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Noman's Shop — Malegaon</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=DM+Sans:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --green: #1a6b3c;
    --green-light: #2d9b5c;
    --green-pale: #e8f5ee;
    --saffron: #f28b00;
    --saffron-light: #ffb347;
    --cream: #fdf8f0;
    --dark: #1a1a1a;
    --gray: #6b7280;
    --border: #e5e7eb;
    --white: #ffffff;
    --shadow: 0 4px 24px rgba(0,0,0,0.08);
    --shadow-hover: 0 12px 40px rgba(0,0,0,0.14);
    --radius: 16px;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'DM Sans', sans-serif;
    background: var(--cream);
    color: var(--dark);
    min-height: 100vh;
  }

  /* ── HEADER ── */
  header {
    background: var(--green);
    color: white;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 20px rgba(0,0,0,0.18);
  }

  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 14px 28px;
    gap: 16px;
  }

  .logo-area { display: flex; flex-direction: column; }
  .logo-area h1 {
    font-family: 'Playfair Display', serif;
    font-size: 1.7rem;
    font-weight: 900;
    letter-spacing: -0.5px;
    line-height: 1;
  }
  .logo-area h1 span { color: var(--saffron-light); }
  .logo-area p {
    font-size: 0.75rem;
    opacity: 0.82;
    margin-top: 2px;
    font-weight: 300;
    letter-spacing: 0.4px;
  }

  .header-right { display: flex; align-items: center; gap: 12px; }

  .search-bar {
    display: flex;
    align-items: center;
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.25);
    border-radius: 50px;
    padding: 7px 16px;
    gap: 8px;
    transition: background 0.2s;
  }
  .search-bar:focus-within { background: rgba(255,255,255,0.22); }
  .search-bar input {
    background: none;
    border: none;
    outline: none;
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.88rem;
    width: 180px;
  }
  .search-bar input::placeholder { color: rgba(255,255,255,0.6); }
  .search-bar svg { opacity: 0.7; }

  .cart-btn {
    background: var(--saffron);
    border: none;
    border-radius: 50px;
    padding: 9px 18px;
    color: white;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    font-size: 0.88rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 7px;
    transition: background 0.2s, transform 0.15s;
    white-space: nowrap;
  }
  .cart-btn:hover { background: #d97800; transform: scale(1.03); }
  .cart-count {
    background: white;
    color: var(--saffron);
    border-radius: 50%;
    width: 20px;
    height: 20px;
    font-size: 0.75rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* Categories nav */
  .cat-nav {
    display: flex;
    gap: 6px;
    padding: 8px 28px 12px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-nav::-webkit-scrollbar { display: none; }
  .cat-btn {
    background: rgba(255,255,255,0.14);
    border: 1px solid rgba(255,255,255,0.22);
    border-radius: 50px;
    padding: 5px 14px;
    color: rgba(255,255,255,0.88);
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    cursor: pointer;
    white-space: nowrap;
    transition: all 0.18s;
  }
  .cat-btn:hover, .cat-btn.active {
    background: var(--saffron);
    border-color: var(--saffron);
    color: white;
  }

  /* ── HERO ── */
  .hero {
    background: linear-gradient(135deg, var(--green) 0%, #0f4a28 100%);
    color: white;
    padding: 48px 28px 56px;
    text-align: center;
    position: relative;
    overflow: hidden;
  }
  .hero::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23ffffff' fill-opacity='0.04'%3E%3Ccircle cx='30' cy='30' r='4'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
  }
  .hero-badge {
    display: inline-block;
    background: var(--saffron);
    border-radius: 50px;
    padding: 4px 14px;
    font-size: 0.78rem;
    font-weight: 600;
    letter-spacing: 0.8px;
    text-transform: uppercase;
    margin-bottom: 14px;
    position: relative;
  }
  .hero h2 {
    font-family: 'Playfair Display', serif;
    font-size: clamp(2rem, 5vw, 3.2rem);
    font-weight: 900;
    line-height: 1.1;
    position: relative;
    margin-bottom: 12px;
  }
  .hero h2 span { color: var(--saffron-light); }
  .hero p {
    font-size: 1rem;
    opacity: 0.85;
    position: relative;
    margin-bottom: 24px;
    max-width: 480px;
    margin-left: auto;
    margin-right: auto;
  }
  .hero-stats {
    display: flex;
    justify-content: center;
    gap: 32px;
    position: relative;
  }
  .stat { text-align: center; }
  .stat-num {
    font-family: 'Playfair Display', serif;
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--saffron-light);
  }
  .stat-label { font-size: 0.72rem; opacity: 0.7; text-transform: uppercase; letter-spacing: 0.6px; }

  /* ── MAIN CONTENT ── */
  .main { max-width: 1200px; margin: 0 auto; padding: 32px 20px 60px; }

  .section-title {
    font-family: 'Playfair Display', serif;
    font-size: 1.5rem;
    font-weight: 700;
    margin-bottom: 20px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .section-title::after {
    content: '';
    flex: 1;
    height: 2px;
    background: linear-gradient(to right, var(--green-light), transparent);
    border-radius: 2px;
  }

  /* Product grid */
  .products-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(220px, 1fr));
    gap: 20px;
  }

  .product-card {
    background: white;
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: var(--shadow);
    transition: box-shadow 0.25s, transform 0.22s;
    cursor: pointer;
    display: flex;
    flex-direction: column;
    animation: fadeUp 0.4s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(18px); }
    to { opacity: 1; transform: translateY(0); }
  }
  .product-card:hover { box-shadow: var(--shadow-hover); transform: translateY(-4px); }

  .product-img {
    width: 100%;
    height: 170px;
    object-fit: cover;
    background: var(--green-pale);
    display: block;
  }
  .product-img-placeholder {
    width: 100%;
    height: 170px;
    background: linear-gradient(135deg, var(--green-pale), #c8e6d5);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
  }

  .product-body { padding: 14px 16px 16px; flex: 1; display: flex; flex-direction: column; }
  .product-cat {
    font-size: 0.7rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.6px;
    color: var(--green-light);
    margin-bottom: 4px;
  }
  .product-name {
    font-family: 'Playfair Display', serif;
    font-size: 1rem;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 4px;
  }
  .product-desc {
    font-size: 0.78rem;
    color: var(--gray);
    margin-bottom: 12px;
    flex: 1;
    line-height: 1.4;
  }
  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 8px;
  }
  .product-price {
    font-family: 'Playfair Display', serif;
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--green);
  }
  .product-price span { font-size: 0.78rem; font-weight: 400; color: var(--gray); }

  .add-btn {
    background: var(--green);
    color: white;
    border: none;
    border-radius: 50px;
    padding: 8px 16px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.82rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 5px;
    transition: background 0.18s, transform 0.15s;
    white-space: nowrap;
  }
  .add-btn:hover { background: var(--green-light); transform: scale(1.04); }
  .add-btn.added { background: var(--saffron); }

  .qty-ctrl {
    display: flex;
    align-items: center;
    gap: 6px;
    background: var(--green-pale);
    border-radius: 50px;
    padding: 4px 8px;
  }
  .qty-ctrl button {
    background: var(--green);
    color: white;
    border: none;
    border-radius: 50%;
    width: 24px;
    height: 24px;
    font-size: 1rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.15s;
  }
  .qty-ctrl button:hover { background: var(--green-light); }
  .qty-ctrl span { font-weight: 700; font-size: 0.9rem; min-width: 18px; text-align: center; }

  /* ── CART MODAL ── */
  .overlay {
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.5);
    z-index: 200;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
    backdrop-filter: blur(3px);
  }
  .overlay.open { opacity: 1; pointer-events: all; }

  .cart-panel {
    position: fixed;
    right: 0; top: 0; bottom: 0;
    width: min(420px, 100vw);
    background: white;
    z-index: 201;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform 0.3s cubic-bezier(0.4, 0, 0.2, 1);
    box-shadow: -8px 0 40px rgba(0,0,0,0.15);
  }
  .cart-panel.open { transform: translateX(0); }

  .cart-header {
    background: var(--green);
    color: white;
    padding: 20px 22px;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .cart-header h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.3rem;
    font-weight: 700;
  }
  .close-btn {
    background: rgba(255,255,255,0.18);
    border: none;
    border-radius: 50%;
    width: 34px;
    height: 34px;
    color: white;
    font-size: 1.2rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background 0.18s;
  }
  .close-btn:hover { background: rgba(255,255,255,0.3); }

  .cart-items { flex: 1; overflow-y: auto; padding: 16px; }
  .cart-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 100%;
    gap: 12px;
    color: var(--gray);
    font-size: 0.9rem;
  }
  .cart-empty-icon { font-size: 3.5rem; }

  .cart-item {
    display: flex;
    gap: 12px;
    padding: 12px 0;
    border-bottom: 1px solid var(--border);
    align-items: center;
    animation: fadeIn 0.2s ease;
  }
  @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
  .cart-item-img {
    width: 60px; height: 60px;
    border-radius: 10px;
    object-fit: cover;
    background: var(--green-pale);
    flex-shrink: 0;
  }
  .cart-item-emoji {
    width: 60px; height: 60px;
    border-radius: 10px;
    background: var(--green-pale);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1.8rem;
    flex-shrink: 0;
  }
  .cart-item-info { flex: 1; min-width: 0; }
  .cart-item-name { font-weight: 600; font-size: 0.88rem; }
  .cart-item-price { color: var(--green); font-weight: 700; font-size: 0.88rem; margin-top: 2px; }
  .cart-item-remove {
    background: none;
    border: none;
    color: #ef4444;
    cursor: pointer;
    font-size: 1rem;
    opacity: 0.7;
    padding: 4px;
    transition: opacity 0.15s;
  }
  .cart-item-remove:hover { opacity: 1; }

  .cart-footer { padding: 16px; border-top: 2px solid var(--border); }
  .cart-summary { margin-bottom: 14px; }
  .cart-row {
    display: flex;
    justify-content: space-between;
    font-size: 0.88rem;
    padding: 4px 0;
    color: var(--gray);
  }
  .cart-row.total {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--dark);
    border-top: 1px solid var(--border);
    margin-top: 6px;
    padding-top: 10px;
  }
  .cart-row.total span:last-child { color: var(--green); }

  .whatsapp-btn {
    width: 100%;
    background: #25d366;
    color: white;
    border: none;
    border-radius: 12px;
    padding: 15px;
    font-family: 'DM Sans', sans-serif;
    font-size: 1rem;
    font-weight: 700;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 10px;
    transition: background 0.18s, transform 0.15s;
    margin-bottom: 10px;
  }
  .whatsapp-btn:hover { background: #1fb855; transform: scale(1.01); }

  .email-btn {
    width: 100%;
    background: var(--green);
    color: white;
    border: none;
    border-radius: 12px;
    padding: 13px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background 0.18s;
  }
  .email-btn:hover { background: var(--green-light); }

  /* ── ORDER FORM MODAL ── */
  .order-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 20px;
    background: rgba(0,0,0,0.55);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.25s;
  }
  .order-modal.open { opacity: 1; pointer-events: all; }
  .order-box {
    background: white;
    border-radius: 20px;
    padding: 28px;
    width: 100%;
    max-width: 440px;
    box-shadow: 0 24px 80px rgba(0,0,0,0.2);
    transform: scale(0.95);
    transition: transform 0.25s;
    max-height: 90vh;
    overflow-y: auto;
  }
  .order-modal.open .order-box { transform: scale(1); }
  .order-box h3 {
    font-family: 'Playfair Display', serif;
    font-size: 1.4rem;
    font-weight: 700;
    margin-bottom: 6px;
  }
  .order-box p { color: var(--gray); font-size: 0.85rem; margin-bottom: 20px; }

  .form-group { margin-bottom: 14px; }
  .form-group label { display: block; font-size: 0.82rem; font-weight: 600; margin-bottom: 5px; color: var(--dark); }
  .form-group input, .form-group textarea, .form-group select {
    width: 100%;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    padding: 10px 14px;
    font-family: 'DM Sans', sans-serif;
    font-size: 0.9rem;
    outline: none;
    transition: border-color 0.18s;
    background: white;
  }
  .form-group input:focus, .form-group textarea:focus, .form-group select:focus {
    border-color: var(--green);
  }
  .form-group textarea { resize: vertical; min-height: 70px; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }

  .modal-actions { display: flex; gap: 10px; margin-top: 18px; }
  .btn-cancel {
    flex: 1;
    padding: 12px;
    border: 1.5px solid var(--border);
    border-radius: 10px;
    background: white;
    font-family: 'DM Sans', sans-serif;
    font-weight: 600;
    cursor: pointer;
    transition: background 0.15s;
  }
  .btn-cancel:hover { background: #f9fafb; }
  .btn-submit {
    flex: 2;
    padding: 12px;
    background: var(--green);
    color: white;
    border: none;
    border-radius: 10px;
    font-family: 'DM Sans', sans-serif;
    font-weight: 700;
    font-size: 0.95rem;
    cursor: pointer;
    transition: background 0.18s;
  }
  .btn-submit:hover { background: var(--green-light); }

  /* ── TOAST ── */
  .toast {
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%) translateY(80px);
    background: var(--dark);
    color: white;
    padding: 12px 24px;
    border-radius: 50px;
    font-size: 0.88rem;
    font-weight: 500;
    z-index: 500;
    transition: transform 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    white-space: nowrap;
  }
  .toast.show { transform: translateX(-50%) translateY(0); }

  /* ── FOOTER ── */
  footer {
    background: var(--dark);
    color: rgba(255,255,255,0.7);
    padding: 32px 28px;
    text-align: center;
  }
  footer h4 {
    font-family: 'Playfair Display', serif;
    color: white;
    font-size: 1.2rem;
    margin-bottom: 8px;
  }
  footer a { color: var(--saffron-light); text-decoration: none; }
  .footer-links { display: flex; justify-content: center; gap: 20px; margin-top: 16px; flex-wrap: wrap; }
  .footer-links a { font-size: 0.82rem; }

  /* No results */
  .no-results {
    grid-column: 1/-1;
    text-align: center;
    padding: 48px 20px;
    color: var(--gray);
  }
  .no-results p { font-size: 1rem; margin-top: 8px; }

  /* Responsive */
  @media (max-width: 600px) {
    .header-top { padding: 12px 16px; }
    .search-bar input { width: 110px; }
    .hero { padding: 32px 16px 40px; }
    .hero-stats { gap: 20px; }
    .main { padding: 20px 12px 48px; }
    .products-grid { grid-template-columns: repeat(2, 1fr); gap: 12px; }
    .product-body { padding: 10px 12px 12px; }
    .product-name { font-size: 0.9rem; }
    .cat-nav { padding: 8px 16px 10px; }
  }
</style>
</head>
<body>

<!-- HEADER -->
<header>
  <div class="header-top">
    <div class="logo-area">
      <h1>Noman's <span>Shop</span></h1>
      <p>📍 Malegaon · Fresh &amp; Fast Delivery</p>
    </div>
    <div class="header-right">
      <div class="search-bar">
        <svg width="15" height="15" fill="none" stroke="white" stroke-width="2" viewBox="0 0 24 24"><circle cx="11" cy="11" r="8"/><path d="M21 21l-4.35-4.35"/></svg>
        <input type="text" id="searchInput" placeholder="Search products…" oninput="filterProducts()">
      </div>
      <button class="cart-btn" onclick="toggleCart()">
        🛒 Cart
        <span class="cart-count" id="cartCount">0</span>
      </button>
    </div>
  </div>
  <div class="cat-nav" id="catNav"></div>
</header>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">🏪 Local &amp; Trusted</div>
  <h2>Your Neighbourhood<br><span>Grocery Store</span></h2>
  <p>Order fresh groceries, dairy, snacks & more — delivered right to your doorstep in Malegaon.</p>
  <div class="hero-stats">
    <div class="stat">
      <div class="stat-num">500+</div>
      <div class="stat-label">Happy Customers</div>
    </div>
    <div class="stat">
      <div class="stat-num">10+</div>
      <div class="stat-label">Products</div>
    </div>
    <div class="stat">
      <div class="stat-num">Fast</div>
      <div class="stat-label">Delivery</div>
    </div>
  </div>
</section>

<!-- MAIN -->
<main class="main">
  <h2 class="section-title" id="sectionTitle">All Products</h2>
  <div class="products-grid" id="productsGrid"></div>
</main>

<!-- FOOTER -->
<footer>
  <h4>Noman's Shop</h4>
  <p>Malegaon, Maharashtra</p>
  <p style="margin-top:6px">📞 <a href="tel:9999999999">9999999999</a> &nbsp;|&nbsp; ✉️ <a href="mailto:nomanshah67@gmail.com">nomanshah67@gmail.com</a></p>
  <div class="footer-links">
    <a href="tel:9999999999">Call Us</a>
    <a href="mailto:nomanshah67@gmail.com">Email Us</a>
    <a href="https://wa.me/919999999999" target="_blank">WhatsApp</a>
  </div>
  <p style="margin-top:20px; font-size:0.75rem; opacity:0.5">© 2026 Noman's Shop · All Rights Reserved</p>
</footer>

<!-- CART OVERLAY + PANEL -->
<div class="overlay" id="overlay" onclick="toggleCart()"></div>
<div class="cart-panel" id="cartPanel">
  <div class="cart-header">
    <h3>🛒 Your Cart</h3>
    <button class="close-btn" onclick="toggleCart()">✕</button>
  </div>
  <div class="cart-items" id="cartItems"></div>
  <div class="cart-footer" id="cartFooter" style="display:none">
    <div class="cart-summary">
      <div class="cart-row"><span>Subtotal</span><span id="subtotal">₹0</span></div>
      <div class="cart-row"><span>Delivery</span><span>Free 🎉</span></div>
      <div class="cart-row total"><span>Total</span><span id="totalAmt">₹0</span></div>
    </div>
    <button class="whatsapp-btn" onclick="openOrderForm('whatsapp')">
      <svg width="20" height="20" fill="white" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
      Order via WhatsApp
    </button>
    <button class="email-btn" onclick="openOrderForm('email')">
      ✉️ Order via Email
