</div>

<!-- ORDER FORM MODAL -->
<div class="order-modal" id="orderModal">
  <div class="order-box">
    <h3>📦 Place Your Order</h3>
    <p>Fill in your details and we'll confirm your order shortly.</p>
    <div class="form-row">
      <div class="form-group">
        <label>Your Name *</label>
        <input type="text" id="custName" placeholder="Full name" required>
      </div>
      <div class="form-group">
        <label>Phone Number *</label>
        <input type="tel" id="custPhone" placeholder="10-digit number" required>
      </div>
    </div>
    <div class="form-group">
      <label>Delivery Address *</label>
      <textarea id="custAddr" placeholder="House no., Street, Area, Malegaon…" required></textarea>
    </div>
    <div class="form-group">
      <label>Preferred Delivery Time</label>
      <select id="custTime">
        <option>Any time</option>
        <option>Morning (8am – 12pm)</option>
        <option>Afternoon (12pm – 4pm)</option>
        <option>Evening (4pm – 8pm)</option>
      </select>
    </div>
    <div class="form-group">
      <label>Special Instructions (optional)</label>
      <textarea id="custNote" placeholder="e.g. Leave at door, call before delivery…" style="min-height:54px"></textarea>
    </div>
    <div class="modal-actions">
      <button class="btn-cancel" onclick="closeOrderForm()">Cancel</button>
      <button class="btn-submit" onclick="submitOrder()">Send Order ✓</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast"></div>

<script>
// ──────────────────────────────────────────────
//  BUSINESS CONFIG
// ──────────────────────────────────────────────
const SHOP = {
  name: "Noman's Shop",
  phone: "9999999999",
  email: "nomanshah67@gmail.com",
  location: "Malegaon, Maharashtra"
};

// ──────────────────────────────────────────────
//  PRODUCTS  (edit here to update your products)
// ──────────────────────────────────────────────
const PRODUCTS = [
  {
    id: 1,
    name: "Aashirvaad Atta (5kg)",
    price: 280,
    category: "Groceries",
    emoji: "🌾",
    img: "",
    desc: "Premium whole wheat flour for soft rotis"
  },
  {
    id: 2,
    name: "Amul Full Cream Milk (1L)",
    price: 68,
    category: "Dairy",
    emoji: "🥛",
    img: "",
    desc: "Fresh full cream milk, chilled daily"
  },
  {
    id: 3,
    name: "Lay's Classic Salted (Pack of 5)",
    price: 95,
    category: "Snacks",
    emoji: "🥔",
    img: "",
    desc: "Crispy potato chips, perfectly salted"
  },
  {
    id: 4,
    name: "Tata Tea Gold (250g)",
    price: 130,
    category: "Beverages",
    emoji: "🍵",
    img: "",
    desc: "Bold & aromatic premium tea blend"
  },
  {
    id: 5,
    name: "Fortune Sunflower Oil (1L)",
    price: 155,
    category: "Groceries",
    emoji: "🫙",
    img: "",
    desc: "Light, healthy cooking oil for everyday use"
  },
  {
    id: 6,
    name: "Amul Butter (500g)",
    price: 275,
    category: "Dairy",
    emoji: "🧈",
    img: "",
    desc: "Creamy salted butter, trusted since years"
  },
  {
    id: 7,
    name: "Haldiram's Bhujia (400g)",
    price: 120,
    category: "Snacks",
    emoji: "🧆",
    img: "",
    desc: "Crispy namkeen snack with rich masala flavour"
  },
  {
    id: 8,
    name: "Coca-Cola (Pack of 6 × 250ml)",
    price: 110,
    category: "Beverages",
    emoji: "🥤",
    img: "",
    desc: "Refreshing cola cans for the whole family"
  },
  {
    id: 9,
    name: "Basmati Rice (5kg)",
    price: 370,
    category: "Groceries",
    emoji: "🍚",
    img: "",
    desc: "Long-grain aged basmati, fragrant & fluffy"
  },
  {
    id: 10,
    name: "Parle-G Biscuits (Pack of 10)",
    price: 85,
    category: "Snacks",
    emoji: "🍪",
    img: "",
    desc: "India's favourite glucose biscuit"
  },
  {
    id: 11,
    name: "Amul Dahi (500g)",
    price: 55,
    category: "Dairy",
    emoji: "🥣",
    img: "",
    desc: "Thick, fresh curd made from pure milk"
  },
  {
    id: 12,
    name: "Nescafé Classic (100g)",
    price: 220,
    category: "Beverages",
    emoji: "☕",
    img: "",
    desc: "Rich instant coffee for your morning kick"
  }
];

// ──────────────────────────────────────────────
//  STATE
// ──────────────────────────────────────────────
let cart = {};
let activeCategory = "All";
let orderChannel = "whatsapp";

// ──────────────────────────────────────────────
//  INIT
// ──────────────────────────────────────────────
function init() {
  buildCatNav();
  renderProducts(PRODUCTS);
}

function buildCatNav() {
  const cats = ["All", ...new Set(PRODUCTS.map(p => p.category))];
  const nav = document.getElementById("catNav");
  nav.innerHTML = cats.map(c =>
    `<button class="cat-btn ${c === 'All' ? 'active' : ''}" onclick="selectCat('${c}', this)">${c}</button>`
  ).join("");
}

function selectCat(cat, btn) {
  activeCategory = cat;
  document.querySelectorAll(".cat-btn").forEach(b => b.classList.remove("active"));
  btn.classList.add("active");
  filterProducts();
  document.getElementById("sectionTitle").textContent =
    cat === "All" ? "All Products" : cat;
}

function filterProducts() {
  const query = document.getElementById("searchInput").value.toLowerCase().trim();
  const filtered = PRODUCTS.filter(p => {
    const matchCat = activeCategory === "All" || p.category === activeCategory;
    const matchQ = !query ||
      p.name.toLowerCase().includes(query) ||
      p.category.toLowerCase().includes(query) ||
      p.desc.toLowerCase().includes(query);
    return matchCat && matchQ;
  });
  renderProducts(filtered);
}

function renderProducts(list) {
  const grid = document.getElementById("productsGrid");
  if (list.length === 0) {
    grid.innerHTML = `<div class="no-results"><span style="font-size:2.5rem">🔍</span><p>No products found. Try a different search.</p></div>`;
    return;
  }
  grid.innerHTML = list.map((p, i) => {
    const qty = cart[p.id] ? cart[p.id].qty : 0;
    const imgHTML = p.img
      ? `<img src="${p.img}" alt="${p.name}" class="product-img" loading="lazy" onerror="this.parentNode.innerHTML='<div class=\\"product-img-placeholder\\">${p.emoji}</div>'">`
      : `<div class="product-img-placeholder">${p.emoji}</div>`;
    const ctrlHTML = qty > 0
      ? `<div class="qty-ctrl">
           <button onclick="changeQty(${p.id}, -1)">−</button>
           <span>${qty}</span>
           <button onclick="changeQty(${p.id}, 1)">+</button>
         </div>`
      : `<button class="add-btn" onclick="addToCart(${p.id})">+ Add</button>`;
    return `<div class="product-card" style="animation-delay:${i * 0.04}s">
      ${imgHTML}
      <div class="product-body">
        <div class="product-cat">${p.category}</div>
        <div class="product-name">${p.name}</div>
        <div class="product-desc">${p.desc}</div>
        <div class="product-footer">
          <div class="product-price">₹${p.price}</div>
          ${ctrlHTML}
        </div>
      </div>
    </div>`;
  }).join("");
}

// ──────────────────────────────────────────────
//  CART LOGIC
// ──────────────────────────────────────────────
function addToCart(id) {
  const p = PRODUCTS.find(x => x.id === id);
  if (!cart[id]) cart[id] = { ...p, qty: 0 };
  cart[id].qty++;
  updateCartUI();
  filterProducts();
  showToast(`"${p.name}" added to cart 🛒`);
}

function changeQty(id, delta) {
  if (!cart[id]) return;
  cart[id].qty += delta;
  if (cart[id].qty <= 0) delete cart[id];
  updateCartUI();
  filterProducts();
}

function removeFromCart(id) {
  delete cart[id];
  updateCartUI();
  filterProducts();
}

function updateCartUI() {
  const items = Object.values(cart);
  const total = items.reduce((s, i) => s + i.price * i.qty, 0);
  const count = items.reduce((s, i) => s + i.qty, 0);

  document.getElementById("cartCount").textContent = count;

  const cartItemsEl = document.getElementById("cartItems");
  const cartFooter = document.getElementById("cartFooter");

  if (items.length === 0) {
    cartItemsEl.innerHTML = `<div class="cart-empty">
      <div class="cart-empty-icon">🛒</div>
      <p>Your cart is empty</p>
      <p style="font-size:0.8rem">Add some products to get started!</p>
    </div>`;
    cartFooter.style.display = "none";
  } else {
    cartItemsEl.innerHTML = items.map(item => {
      const imgHTML = item.img
        ? `<img src="${item.img}" class="cart-item-img" alt="${item.name}" onerror="this.parentNode.innerHTML='<div class=\\"cart-item-emoji\\">${item.emoji}</div>'">`
        : `<div class="cart-item-emoji">${item.emoji}</div>`;
      return `<div class="cart-item">
        ${imgHTML}
        <div class="cart-item-info">
          <div class="cart-item-name">${item.name}</div>
          <div class="cart-item-price">₹${item.price} × ${item.qty} = ₹${item.price * item.qty}</div>
          <div class="qty-ctrl" style="margin-top:6px">
            <button onclick="changeQty(${item.id}, -1)">−</button>
            <span>${item.qty}</span>
            <button onclick="changeQty(${item.id}, 1)">+</button>
          </div>
        </div>
        <button class="cart-item-remove" onclick="removeFromCart(${item.id})" title="Remove">🗑</button>
      </div>`;
    }).join("");
    cartFooter.style.display = "block";
    document.getElementById("subtotal").textContent = `₹${total}`;
    document.getElementById("totalAmt").textContent = `₹${total}`;
  }
}

function toggleCart() {
  const panel = document.getElementById("cartPanel");
  const overlay = document.getElementById("overlay");
  panel.classList.toggle("open");
  overlay.classList.toggle("open");
  document.body.style.overflow = panel.classList.contains("open") ? "hidden" : "";
}

// ──────────────────────────────────────────────
//  ORDER FORM
// ──────────────────────────────────────────────
function openOrderForm(channel) {
  orderChannel = channel;
  document.getElementById("orderModal").classList.add("open");
}
function closeOrderForm() {
  document.getElementById("orderModal").classList.remove("open");
}

function submitOrder() {
  const name = document.getElementById("custName").value.trim();
  const phone = document.getElementById("custPhone").value.trim();
  const addr = document.getElementById("custAddr").value.trim();
  const time = document.getElementById("custTime").value;
  const note = document.getElementById("custNote").value.trim();

  if (!name || !phone || !addr) {
    showToast("⚠️ Please fill all required fields");
    return;
  }
  if (!/^\d{10}$/.test(phone)) {
    showToast("⚠️ Enter a valid 10-digit phone number");
    return;
  }

  const items = Object.values(cart);
  const total = items.reduce((s, i) => s + i.price * i.qty, 0);

  let orderText = `🛒 *New Order — Noman's Shop*\n\n`;
  orderText += `👤 *Customer:* ${name}\n`;
  orderText += `📞 *Phone:* ${phone}\n`;
  orderText += `📍 *Address:* ${addr}\n`;
  orderText += `🕐 *Delivery Time:* ${time}\n`;
  if (note) orderText += `📝 *Note:* ${note}\n`;
  orderText += `\n🧾 *Order Items:*\n`;
  items.forEach(i => {
    orderText += `  • ${i.name} × ${i.qty} = ₹${i.price * i.qty}\n`;
  });
  orderText += `\n💰 *Total: ₹${total}*\n`;
  orderText += `\n_Order placed via Noman's Shop website_`;

  if (orderChannel === "whatsapp") {
    const wa = `https://wa.me/91${SHOP.phone}?text=${encodeURIComponent(orderText)}`;
    window.open(wa, "_blank");
  } else {
    const subject = encodeURIComponent(`New Order from ${name} — Noman's Shop`);
    const body = encodeURIComponent(orderText.replace(/\*/g, ""));
    window.location.href = `mailto:${SHOP.email}?subject=${subject}&body=${body}`;
  }

  closeOrderForm();
  toggleCart();
  cart = {};
  updateCartUI();
  filterProducts();
  showToast("🎉 Order sent! We'll confirm soon.");
}

// ──────────────────────────────────────────────
//  TOAST
// ──────────────────────────────────────────────
let toastTimer;
function showToast(msg) {
  const t = document.getElementById("toast");
  t.textContent = msg;
  t.classList.add("show");
  clearTimeout(toastTimer);
  toastTimer = setTimeout(() => t.classList.remove("show"), 2800);
}

// ──────────────────────────────────────────────
init();
</script>
</body>
</html>
